# API Server Configuration
NODE_ENV=production
PORT=4000

# Authentication — comma-separated API keys
API_KEYS=your-secret-api-key-here

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# OpenAI
OPENAI_API_KEY=sk-...

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/okstours

# Telegram (optional)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
